{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barrosohub.github.io/frontend-stack-blueprint/schemas/evals.schema.json",
  "title": "Frontend Blueprint Golden Agent Scenarios",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "minimum_score", "scenarios"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "minimum_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt",
          "expected_profiles",
          "required_capabilities",
          "forbidden_capabilities",
          "required_checks"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "prompt": { "type": "string", "minLength": 1 },
          "expected_profiles": { "$ref": "#/$defs/strings" },
          "required_capabilities": { "$ref": "#/$defs/strings" },
          "forbidden_capabilities": { "$ref": "#/$defs/strings" },
          "required_checks": { "$ref": "#/$defs/strings" }
        }
      }
    }
  },
  "$defs": {
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
