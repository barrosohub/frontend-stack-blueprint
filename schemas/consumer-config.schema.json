{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barrosohub.github.io/frontend-stack-blueprint/schemas/consumer-config.schema.json",
  "title": "Frontend Blueprint Consumer Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["blueprint_version", "profiles", "waivers"],
  "properties": {
    "$schema": { "type": "string" },
    "blueprint_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "reason", "owner", "expires"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "expires": { "type": "string", "format": "date" }
        }
      }
    }
  }
}
