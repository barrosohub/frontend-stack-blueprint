{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barrosohub.github.io/frontend-stack-blueprint/schemas/agent-contract.schema.json",
  "title": "Frontend Blueprint Agent Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "blueprint_version",
    "source",
    "foundations",
    "activation_rules",
    "prohibited",
    "references"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.0" },
    "blueprint_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "source": { "const": "stack.yaml" },
    "foundations": { "$ref": "#/$defs/rules" },
    "activation_rules": { "$ref": "#/$defs/rules" },
    "prohibited": { "$ref": "#/$defs/rules" },
    "references": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rule"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
          },
          "rule": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
